# Required: model API key used in src/agent.ts
DEEPSEEK_API_KEY=your_deepseek_api_key

# Required: Napcat token used in src/napcat.ts
NAPCAT_TOKEN=your_napcat_token

# Required: Crawl4AI base URL used by web_fetch tool
CRAWL4AI_BASE_URL=http://localhost:11235

# Optional/legacy: used by some utility modules
SILICONFLOW_API_KEY=your_siliconflow_api_key
